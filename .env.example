# Phakathi Flow local development
#
# Base44-hosted apps normally receive app parameters from the Base44 runtime.
# Keep secrets out of this file. Copy to .env.local only if your local wrapper
# or self-hosted migration layer needs explicit values.

VITE_BASE44_APP_ID=
VITE_BASE44_BACKEND_URL=
VITE_BASE44_PUBLIC_URL=http://localhost:5173

# Optional future self-hosted backend values
DATABASE_URL=postgresql://user:password@localhost:5432/phakathi_flow
JWT_SECRET=replace-with-a-long-random-secret
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
