# Phakathi Flow local development
#
# Copy to .env.local for local development. The app now talks to the self-hosted
# local API.

VITE_API_BASE_URL=http://127.0.0.1:4000/api

# Optional future production backend values
DATABASE_URL=postgresql://user:password@localhost:5432/phakathi_flow
JWT_SECRET=replace-with-a-long-random-secret
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
OPENAI_API_KEY=
OPENAI_MEETING_MODEL=gpt-4.1-mini
EMAIL_PROVIDER_API_KEY=
SMS_PROVIDER_API_KEY=

# Browser/device push notifications
# Generate persistent keys with: npm run push:vapid
# Keep these stable; changing them can require users to resubscribe their devices.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@phakathiholdings.local

# Netlify scheduled notifications
# Use a deployed backend/API URL when Netlify should trigger notification scans
# against persistent backend storage rather than local JSON fallback.
PHAKATHI_API_BASE_URL=
SCHEDULED_NOTIFICATION_SECRET=
ENABLE_LOCAL_NOTIFICATION_SCHEDULER=true
