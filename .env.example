# Phakathi Flow local development
#
# Copy to .env.local for local development. The app now talks to the self-hosted
# local API.

VITE_API_BASE_URL=http://127.0.0.1:4000/api

# Optional future production backend values
DATABASE_URL=postgresql://user:password@localhost:5432/phakathi_flow
JWT_SECRET=replace-with-a-long-random-secret
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
OPENAI_API_KEY=
EMAIL_PROVIDER_API_KEY=
SMS_PROVIDER_API_KEY=
