{
  "name": "OKR",
  "type": "object",
  "properties": {
    "review_id": {
      "type": "string"
    },
    "employee_email": {
      "type": "string"
    },
    "owner_email": {
      "type": "string",
      "description": "Person accountable for this goal"
    },
    "level": {
      "type": "string",
      "enum": [
        "group",
        "subsidiary",
        "team",
        "individual"
      ],
      "default": "group"
    },
    "portfolio_id": {
      "type": "string",
      "description": "Optional portfolio linked to this OKR"
    },
    "project_id": {
      "type": "string",
      "description": "Optional project linked to this OKR"
    },
    "objective": {
      "type": "string"
    },
    "key_results": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "progress": {
      "type": "number",
      "description": "Progress percentage 0-100"
    },
    "period": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "on_track",
        "at_risk",
        "completed",
        "not_started"
      ],
      "default": "not_started"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "objective",
    "employee_email",
    "period"
  ]
}
