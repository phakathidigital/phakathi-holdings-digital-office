{
  "name": "Project",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Project name"
    },
    "description": {
      "type": "string",
      "description": "Project description"
    },
    "portfolio_id": {
      "type": "string",
      "description": "Portfolio this project belongs to"
    },
    "okr_id": {
      "type": "string",
      "description": "Optional OKR this project supports"
    },
    "subsidiary": {
      "type": "string",
      "enum": [
        "Phakathi Holdings",
        "Empoweryst",
        "Micky Mouse School / Baby Geniuses",
        "Phakathi Capital",
        "Key Experts",
        "Kaelo Education",
        "Kaelo",
        "Synergex Health"
      ],
      "description": "Which subsidiary this project belongs to"
    },
    "status": {
      "type": "string",
      "enum": [
        "planning",
        "in_progress",
        "on_hold",
        "completed"
      ],
      "default": "planning"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "budget": {
      "type": "number",
      "description": "Project budget"
    },
    "team_members": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Email addresses of team members"
    },
    "color": {
      "type": "string",
      "description": "Project color theme"
    },
    "progress": {
      "type": "number",
      "description": "Read-only calculated progress from linked task completion. Manual values are ignored by the API."
    }
  },
  "required": [
    "name"
  ]
}
